# Zapier Catch Hook — fired on Download (JSON: name, email, company, date).
#
# Put `VITE_*` vars in `.env` (shared) or mode-specific files loaded by npm scripts:
#   npm run dev        → dotenv -c development  (.env, .env.development, .env.local, …)
#   npm run build      → dotenv -c production   (.env, .env.production, …)
#   npm run build:pages→ dotenv -c pages        (.env, .env.pages, …)
# Vite also loads env files; keep webhook URL in `.env` unless you override per mode.
VITE_ZAPIER_WEBHOOK_URL=
